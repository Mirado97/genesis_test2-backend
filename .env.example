# Скопируй в .env и заполни значения

# Сервер
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/nft_marketplace

# JWT — сгенерируй случайную строку: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Telegram Bot Token — получи у @BotFather
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN

# CORS — адрес фронтенда маркетплейса
FRONTEND_URL=http://localhost:3000
